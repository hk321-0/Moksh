name: Deploy Moksh to Firebase Hosting (GCP)

on:
  push:
    branches: [ main ]
  # Also allow manual trigger from GitHub Actions UI
  workflow_dispatch:

jobs:
  deploy:
    name: Build & Deploy to Firebase
    runs-on: ubuntu-latest

    steps:
      # 1. Check out the repository
      - name: Checkout code
        uses: actions/checkout@v4

      # 2. Deploy to Firebase Hosting
      #    FIREBASE_TOKEN is a CI token generated by:
      #    `npx firebase-tools login:ci`
      #    Add it as a GitHub Actions secret named FIREBASE_TOKEN
      - name: Deploy to Firebase Hosting
        uses: FirebaseExtended/action-hosting-deploy@v0
        with:
          repoToken:      '${{ secrets.GITHUB_TOKEN }}'
          firebaseServiceAccount: '${{ secrets.FIREBASE_SERVICE_ACCOUNT }}'
          channelId:      live
          projectId:      'moksh-593b0'
          # The folder that contains firebase.json
          entryPoint:     './exam-wellbeing-bot'

      - name: Print live URL
        run: echo "🚀 Moksh is live on Firebase Hosting!"